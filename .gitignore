# ============================================================
# Office binaries (broad deny, with explicit deliverables allowed below)
# ============================================================
*.pdf
*.docx
*.pptx
IRC/
irc.pdf

# Keep these deliverables
!docs/project_explainer.docx
!docs/project_explainer_v2.docx
!docs/architecture_diagram.pptx
!docs/rag-system/figures/*.pdf
!docs/rag-system/figures/*.png

# Generated report bundles in docs/rag-system (recreatable via generate_*.py)
docs/rag-system/*.docx

